unit uControleLog;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Data.DB, Vcl.DBCtrls, Vcl.Grids, Vcl.DBGrids, Vcl.StdCtrls, Vcl.Buttons, Vcl.Mask,
  Vcl.ComCtrls, Vcl.ExtCtrls, System.UITypes,
  uDtmConexao, FireDAC.Stan.Intf, FireDAC.Stan.Option, FireDAC.Stan.Param, FireDAC.Stan.Error, FireDAC.DatS,
  FireDAC.Phys.Intf, FireDAC.DApt.Intf, FireDAC.Stan.Async, FireDAC.DApt, FireDAC.Comp.DataSet, FireDAC.Comp.Client, uEnum,
  RxToolEdit, RxCurrEdit, System.IniFiles;

type
  TfrmLog = class(TForm)
    pnl1: TPanel;
    pnl2: TPanel;
    grd1: TDBGrid;
    QryLog: TFDQuery;
    dsLog: TDataSource;
    f1QryLogID: TFDAutoIncField;
    QryLogDATA_HORA: TSQLTimeStampField;
    f2QryLogUSUARIO: TStringField;
    f2QryLogACAO: TStringField;
    f2QryLogTELA: TStringField;
    f2QryLogDESCRICAO: TStringField;
    lblIndice: TLabel;
    btnPesquisar: TBitBtn;
    mskPesquisar: TMaskEdit;
    procedure edtmskpesquisarChange(Sender: TObject);
    procedure btnPesquisarClick(Sender: TObject);
  private
    { Private declarations }
    SelectOriginal:string;
  public
    { Public declarations }
    IndiceAtual:string;
  end;

var
  frmLog: TfrmLog;

implementation


{$R *.dfm}

procedure TfrmLog.btnPesquisarClick(Sender: TObject);
var I:Integer;
    TipoCampo:TFieldType;
    NomeCampo: string;
    WhereOrAnd: string;
    CondicaoSQL: string;
begin

  if mskPesquisar.Text='' then
  begin
    QryLog.Close;
    QryLog.SQL.Clear;
    QryLog.SQL.Add(SelectOriginal);
    QryLog.Open;
    Abort;
  end;

  for I := 0 to QryLog.FieldCount-1 do
  begin
    if QryLog.Fields[i].FieldName=IndiceAtual then
    begin
      TipoCampo := QryLog.Fields[i].DataType;
      if QryLog.Fields[i].Origin<>'' then
      begin
        if Pos('.',QryLog.Fields[i].Origin) > 1 then
        NomeCampo := QryLog.Fields[i].Origin
        else
        NomeCampo := QryLog.Fields[i].Origin+'.'+QryLog.Fields[i].FieldName
      end
      else
      NomeCampo := QryLog.Fields[i].FieldName;
      Break;
    end;
  end;

  if Pos('where', LowerCase(SelectOriginal)) > 0 then
  begin
    WhereOrAnd := ' and ';
  end
  else
  begin
    WhereOrAnd := ' where ';
  end;

  if (TipoCampo=ftString) or (TipoCampo=ftWideString) then
  begin
    CondicaoSQL := WhereOrAnd+' '+ NomeCampo + ' LIKE '+QuotedStr('%'+mskPesquisar.Text+'%');
  end
  else if (TipoCampo in [ftInteger, ftSmallint, ftAutoInc]) then
  begin
    CondicaoSQL := WhereOrAnd+''+NomeCampo + '='+mskPesquisar.Text
  end

  //AUTORAL DO PEPPA, MATEUS E LEO

  else if (TipoCampo in [ftDate, ftDateTime, ftdate, ftTimeStamp]) then
  begin
      CondicaoSQL := WhereOrAnd+' '+' CAST '+'('+NomeCampo +' as date)' + '='+QuotedStr(mskPesquisar.Text)
  end


 else if (TipoCampo in [ftFloat, ftCurrency, ftFMTBcd]) then
 begin
    CondicaoSQl := WhereOrAnd+''+NomeCampo + '='+StringReplace(mskPesquisar.Text,',','.',[rfReplaceAll]);
 end;


  QryLog.Close;
  QryLog.SQL.Clear;
  QryLog.SQL.Add(SelectOriginal);
  QryLog.SQL.Add(CondicaoSQL);
  QryLog.Open;

  mskPesquisar.Text:='';
  mskPesquisar.SetFocus;

end;

procedure TfrmLog.edtmskpesquisarChange(Sender: TObject);
var Date:TDateTime; Texto, N: string; poscursor: Integer;
begin
  if(trim(TMaskEdit(Sender).Text) = '')then
    Exit;

  if(QryLog.FieldByName(IndiceAtual).DataType in [ftString, ftWideString] )then
  begin
    QryLog.Locate(IndiceAtual, TMaskEdit(Sender).Text, [loPartialKey])
  end
  else if(QryLog.FieldByName(IndiceAtual).DataType in [ftFloat, ftCurrency, ftFMTBcd] )then
  begin
   try
     QryLog.Locate(IndiceAtual, TMaskEdit(Sender).Text, [])
   except

   end;
  end
  else if(QryLog.FieldByName(IndiceAtual).DataType in [ftDate, ftDateTime, ftTimeStamp] )then
  begin
   if TryStrToDate(TMaskEdit(Sender).Text, Date) then
   begin
     QryLog.Locate(IndiceAtual, Date, []);
   end
  end
  else
     QryLog.Locate(IndiceAtual, TMaskEdit(Sender).Text, [])

end.
